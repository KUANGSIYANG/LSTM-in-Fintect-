hs300_stock_predict/data/sp500_2024split/*.csv

# Large non-financial source file
hs300_stock_predict/data/non_financial/electricity.csv

# Model checkpoints and full prediction dumps
hs300_stock_predict/outputs/**/*.pt
hs300_stock_predict/outputs/**/*_predictions.csv
